# Copy this file to ".env" in core-api/ and edit values as needed.
# All values shown are the defaults — only override what you need.

PORT=4000

# MongoDB — local install on default port
MONGO_URL=mongodb://localhost:27017/crowdshield

# ML service running locally
ML_URL=http://localhost:5000

# Simulator tick speed (60 = realistic, 2 = fast demo)
TICK_SECONDS=60

# Escalation thresholds (in ticks)
TIER2_AFTER=5
TIER3_AFTER=10

# Optional: explicit dataset path (auto-detects ../../minute_level_dataset.csv otherwise)
# DATASET_PATH=C:/Users/jayja/OneDrive/Desktop/LAK/Lakshya/Lakshya-NoDocker/minute_level_dataset.csv
